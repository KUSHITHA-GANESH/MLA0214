import math
from collections import Counter

data = [
    ["Peak", "Rainy", "High", "Yes"],
    ["Peak", "Clear", "High", "Yes"],
    ["OffPeak", "Clear", "Low", "No"],
    ["OffPeak", "Rainy", "Medium", "No"]
]

features = ["TimeOfDay", "Weather", "VehicleCount"]

# Entropy calculation
def entropy(data):
    labels = [row[-1] for row in data]
    count = Counter(labels)
    total = len(data)
    ent = 0
    for c in count.values():
        p = c / total
        ent -= p * math.log2(p)
    return ent

# Information Gain
def info_gain(data, index):
    total_entropy = entropy(data)
    values = set(row[index] for row in data)
    weighted_entropy = 0
    
    for v in values:
        subset = [row for row in data if row[index] == v]
        weighted_entropy += (len(subset)/len(data)) * entropy(subset)
    
    return total_entropy - weighted_entropy

# Build tree
def build_tree(data, features):
    labels = [row[-1] for row in data]
    
    if labels.count(labels[0]) == len(labels):
        return labels[0]
    
    gains = [info_gain(data, i) for i in range(len(features))]
    best_attr = gains.index(max(gains))
    
    tree = {features[best_attr]: {}}
    values = set(row[best_attr] for row in data)
    
    for v in values:
        subset = [row[:best_attr] + row[best_attr+1:] for row in data if row[best_attr] == v]
        sub_features = features[:best_attr] + features[best_attr+1:]
        tree[features[best_attr]][v] = build_tree(subset, sub_features)
    
    return tree

tree = build_tree(data, features)
print("Decision Tree:", tree)

# Prediction
def predict(tree, features, sample):
    if not isinstance(tree, dict):
        return tree
    
    root = next(iter(tree))
    index = features.index(root)
    value = sample[index]
    
    return predict(tree[root][value], features, sample)

test = ["Peak", "Rainy", "High"]
print("Prediction:", predict(tree, features, test))
